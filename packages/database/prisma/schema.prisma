generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "js"
}

datasource db {
  provider = "sqlite"
}

enum VALID_SETTING {
  DISCORD_WEBHOOK
  NTFY_WEBHOOK
}

model Subscription {
  id                 Int       @id @default(autoincrement())
  name               String
  image              String
  price              Decimal
  paymentMethod      String
  billingDate        DateTime
  lastBillingDate    DateTime?
  category           Category? @relation(fields: [categoryId], references: [id])
  totalSpend         Decimal   @default(0.00)
  previousTotalSpend Decimal   @default(0.00)
  shouldNotifyExpiry Boolean   @default(true)
  categoryId         Int?
}

model MonthlyReport {
  id   Int      @id @default(autoincrement())
  year Int      @unique
  jan  Decimal?
  feb  Decimal?
  mar  Decimal?
  apr  Decimal?
  may  Decimal?
  jun  Decimal?
  jul  Decimal?
  aug  Decimal?
  sept Decimal?
  oct  Decimal?
  nov  Decimal?
  dec  Decimal?

  @@index([year])
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  subscriptions Subscription[]
}

model Settings {
  id Int @id @default(autoincrement())
  name VALID_SETTING @unique
  value String
}
